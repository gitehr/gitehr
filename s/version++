# set -v  # Enable verbose mode
set -euo pipefail  # Exit on error

# scripts may need to be made executable on some platforms before they can be run
# chmod +x s/<filename> is the command to do this on unixy systems

if [[ "${1-}" != "--manual" ]]; then
  cat >&2 <<'EOF'
GitEHR releases are managed by release-plz.

Normal release flow:
  1. Use conventional commits.
  2. Push/merge to main.
  3. Merge the release-plz Release PR.

release-plz then creates the git tag and GitHub Release. Do not tag locally.

Manual fallback, only when deliberately bypassing release-plz:
  s/version++ --manual [patch|minor|major]

The manual fallback bumps local version files but does not commit or tag.
EOF
  exit 1
fi

shift
bump="patch"
if [[ -n "${1-}" ]]; then
  case "$1" in
    patch|minor|major)
      bump="$1"
      ;;
    *)
      echo "Usage: s/version++ [patch|minor|major]" >&2
      exit 1
      ;;
  esac
fi

cargo set-version --bump "$bump"

version="$(awk -F\" '/^version =/ {print $2; exit}' Cargo.toml)"
if [[ -z "$version" ]]; then
  echo "Could not read workspace version from Cargo.toml." >&2
  exit 1
fi

cargo set-version --manifest-path gui/src-tauri/Cargo.toml "$version"

(
  cd gui
  npm version "$version" --no-git-tag-version >/dev/null
  node -e '
    const fs = require("fs");
    const path = "src-tauri/tauri.conf.json";
    const config = JSON.parse(fs.readFileSync(path, "utf8"));
    config.version = process.argv[1];
    fs.writeFileSync(path, `${JSON.stringify(config, null, 2)}\n`);
  ' "$version"
)

echo "Bumped local versions to $version. No commit or tag was created."
